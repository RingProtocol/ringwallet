{
  "name": "ring-wallet-proxy-server",
  "version": "1.0.0",
  "description": "Ring Wallet DApp proxy server with Neon Postgres — deploy to Vercel",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "seed": "node seed.js",
    "db:init": "node -e \"import('./db.js').then(m => m.initDB()).then(() => { console.log('OK'); process.exit(0) })\""
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "node-html-parser": "^6.1.13"
  }
}
