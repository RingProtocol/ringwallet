{
  "name": "new-wallet",
  "version": "1.0.0",
  "description": "A React wallet application with Passkey authentication",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "vite:dev": "vite --config apps/pwa/vite.config.ts",
    "vite:build": "tsc && vite build --config apps/pwa/vite.config.ts",
    "vite:preview": "vite preview --config apps/pwa/vite.config.ts",
    "ext:dev": "vite --config apps/extension/vite.config.ts",
    "ext:build": "vite build --config apps/extension/vite.config.ts && node apps/extension/copy-assets.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "db:seed": "node scripts/seed.js"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "cbor-x": "^1.6.0",
    "ed25519-hd-key": "^1.3.0",
    "ethers": "^6.16.0",
    "next": "latest",
    "node-html-parser": "^7.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "serve": "^14.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "@vitest/coverage-v8": "^1.6.0",
    "typescript": "^5.3.3",
    "vite": "^4.4.5",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^1.6.0"
  }
}
