{
  "name": "new-wallet",
  "version": "1.0.0",
  "description": "A React wallet application with Passkey authentication",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "vite --config apps/pwa/vite.config.js",
    "build": "vite build --config apps/pwa/vite.config.js",
    "preview": "vite preview --config apps/pwa/vite.config.js",
    "start": "serve -s dist -l ${PORT:-3000}"
  },
  "dependencies": {
    "cbor-x": "^1.6.0",
    "ethers": "^6.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "serve": "^14.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "vite": "^4.4.5",
    "vite-plugin-pwa": "^1.2.0"
  }
}
