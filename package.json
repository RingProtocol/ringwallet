{
  "name": "new-wallet",
  "version": "1.0.0",
  "description": "A React wallet application with Passkey authentication",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "vite:dev": "vite --config apps/pwa/vite.config.ts --port 3003",
    "vite:build": "tsc && vite build --config apps/pwa/vite.config.ts",
    "vite:preview": "vite preview --config apps/pwa/vite.config.ts",
    "ext:dev": "vite --config apps/extension/vite.config.ts",
    "ext:build": "vite build --config apps/extension/vite.config.ts && node apps/extension/copy-assets.ts",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:prepare": "node scripts/test-prepare.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:chain": "vitest run --config vitest.chain.config.ts",
    "test:chain:watch": "vitest --config vitest.chain.config.ts",
    "test:chain:doctor": "node test/evmchain/cli/run.mjs doctor",
    "test:chain:fork-url": "node test/evmchain/cli/run.mjs fork-url",
    "test:chain:wait-anvil": "node test/evmchain/cli/run.mjs wait-anvil",
    "test:multichain": "vitest run --config vitest.multichain.config.ts",
    "test:multichain:watch": "vitest --config vitest.multichain.config.ts",
    "test:multichain:solana-local": "node test/solana-local/wait-rpc.mjs && vitest run --config vitest.multichain.config.ts test/multichain/solana.local.integration.spec.ts",
    "test:multichain:bitcoin-regtest": "vitest run --config vitest.multichain.config.ts test/multichain/bitcoin.regtest.integration.spec.ts",
    "test:e2e": "npx playwright test --config test/playwright/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config test/playwright/playwright.config.ts --ui",
    "test:e2e:anvil": "node test/Playwright/scripts/start-anvil.mjs 998 8545 & node test/Playwright/scripts/start-anvil.mjs 11155111 8546 & wait",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "validate:staged": "lint-staged && yarn typecheck",
    "validate:ci": "yarn typecheck && yarn test",
    "dappsdk:minify": "node scripts/minify-dappsdk.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bech32": "^2.0.0",
    "bip32": "^5.0.1",
    "bitcoinjs-lib": "^7.0.1",
    "cbor-x": "^1.6.0",
    "ed25519-hd-key": "^1.3.0",
    "ethers": "^6.16.0",
    "next": "latest",
    "node-html-parser": "^7.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "serve": "^14.2.0",
    "tiny-secp256k1": "^2.2.4",
    "undici": "^6.21.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^4.4.5",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5"
  }
}
