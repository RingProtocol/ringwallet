# Copy to .env.test (local / CI secrets) — do not commit real keys.
# Used by Node scripts to build anvil --fork-url; not bundled into the PWA by default.

# Alchemy API key (PWA + optional anvil fork URL builder).
# Same key is used when building multichain test URLs if the TEST_* overrides below are unset
# (see `test/multichain/lib/resolveTestRpc.ts`).
ALCHEMY_API_KEY=

# Or use the Vite env name (also picked up by Node test loaders):
# VITE_ALCHEMY_RPC_KEY=

# Fallback Sepolia RPC for `anvil --fork-url` when ALCHEMY_API_KEY / VITE_ALCHEMY_RPC_KEY are NOT set.
# If you use Alchemy (recommended), configure allowlist in dashboard instead — fork-url prefers Alchemy when key exists.
# TESTCHAIN_FORK_URL_SEPOLIA=https://rpc.sepolia.org
# TESTCHAIN_FORK_URL=

# Optional: default port for single-chain local fork
# ANVIL_PORT=8545

# ── Optional: `yarn test:multichain` (Bitcoin / Solana / Tron smoke tests) ──
# With ALCHEMY_API_KEY or VITE_ALCHEMY_RPC_KEY set, tests default to Alchemy URLs (no need to
# paste full URLs unless you want a different host):
#
#   Solana devnet:  https://solana-devnet.g.alchemy.com/v2/<key>   (default cluster)
#   Solana mainnet: https://solana-mainnet.g.alchemy.com/v2/<key>  (set TEST_SOLANA_ALCHEMY_CLUSTER=mainnet)
#   Tron:           https://tron-mainnet.g.alchemy.com/v2/<key>    (wallet/getnowblock)
#   Bitcoin:        JSON-RPC getblockcount on
#                   https://bitcoin-testnet.g.alchemy.com/v2/<key> (default)
#                   or bitcoin-mainnet… when TEST_BITCOIN_ALCHEMY_NETWORK=mainnet
#
# Overrides (full URL / Esplora base — optional):
# TEST_SOLANA_RPC_URL=https://solana-devnet.g.alchemy.com/v2/...
# TEST_SOLANA_ALCHEMY_CLUSTER=devnet
# TEST_TRON_API_URL=https://api.shasta.trongrid.io
# TEST_BITCOIN_INDEXER_URL=https://mempool.space/testnet/api
# TEST_BITCOIN_ALCHEMY_NETWORK=testnet
#
# Skip all multichain integration tests (e.g. air-gapped CI):
# SKIP_MULTICHAIN_INTEGRATION=1
