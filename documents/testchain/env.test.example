# Copy to .env.test (local / CI secrets) — do not commit real keys.
# Used by Node scripts to build anvil --fork-url; not bundled into the PWA by default.

# Alchemy API key (PWA + optional anvil fork URL builder).
ALCHEMY_API_KEY=

# Fallback Sepolia RPC for `anvil --fork-url` when ALCHEMY_API_KEY / VITE_ALCHEMY_RPC_KEY are NOT set.
# If you use Alchemy (recommended), configure allowlist in dashboard instead — fork-url prefers Alchemy when key exists.
# TESTCHAIN_FORK_URL_SEPOLIA=https://rpc.sepolia.org
# TESTCHAIN_FORK_URL=

# Optional: default port for single-chain local fork
# ANVIL_PORT=8545
